{
  "normalize": {
    "lower": true,
    "ascii_fold": true,
    "replace_map": {
      "&": " and ",
      "/": " ",
      "_": " ",
      "-": " "
    },
    "strip_chars": ["$", "%", "#"],
    "acronyms": {
      "cogs": "costs of goods sold",
      "other opex": "other operating expenses",
      "capex": "capital expenditures",
      "d&a": "depreciation and amortization",
      "depr": "depreciation",
      "depre": "depreciation",
      "amort": "amortization",
      "ar": "accounts receivable",
      "ap": "accounts payable",
      "ppe": "property plant equipment",
      "r&d": "research and development",
      "dta": "deferred tax assets"
    }
  },

  "thresholds": {
    "auto_map": 100,
    "review_min": 75
  },

  "ignore_contains": [
    "gross profit",
    "ebitda",
    "ebit",
    "operating income",
    "net income",
    "operating profit",
    "profit margin",
    "gross margin"
  ],

